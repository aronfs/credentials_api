{
  "name": "archivero-seguro-backend",
  "version": "1.0.0",
  "description": "Archivero Seguro de Emails y Contraseñas - Backend",
  "module": "src/main.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "bun build src/main.ts --outdir ./dist",
    "start": "bun run dist/main.js",
    "seed": "bun run prisma/seed.ts",
    "prisma:generate": "bunx prisma generate",
    "prisma:push": "bunx prisma db push",
    "prisma:studio": "bunx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.7.0",
    "prisma": "^5.22.0",
    "typescript": "^5.6.2"
  }
}

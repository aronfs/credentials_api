meta {
  name: Upload Profile Image
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/profile-image
  body: multipartForm
  auth: none
}

headers {
  Authorization: Bearer {{access_token}}
}

body:multipart-form {
  file: @file(/home/aaronfs/Descargas/655820015_2391026634750108_7668639975339766925_n.jpg) @contentType(image/jpeg)
}

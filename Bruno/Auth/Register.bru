meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Nuevo Usuario",
    "email": "nuevo@example.com",
    "password": "Password123",
    "pin": "1234"
  }
}

meta {
  name: Update Credential
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/api/credentials/{{credentialId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "serviceName": "Google Actualizado",
    "username": "nuevo_usuario",
    "notes": "Notas actualizadas",
    "tags": ["google", "actualizado"],
    "strength": 90
  }
}

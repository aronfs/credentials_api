meta {
  name: Update Category
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/api/categories/{{categoryId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "name": "Redes Sociales",
    "color": "#ef4444",
    "icon": "heart",
    "isActive": true
  }
}
